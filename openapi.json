      "get": {
        "summary": "Get transformer detail",
        "tags": [
          "Transformers"
        ],
        "description": "Single distribution transformer by code.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "code",
            "required": true,
            "description": "Transformer code (e.g. DT-001)"
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "description": "Transformer code (e.g. DT-001)"
                        },
                        "name": {
                          "type": "string",
                          "description": "Human-readable name (e.g. Malviya Nagar DT 1)"
                        },
                        "feederCode": {
                          "type": "string",
                          "description": "Feeder code this DT belongs to"
                        },
                        "capacityKva": {
                          "type": "integer",
                          "description": "Transformer capacity in kVA"
                        },
                        "syncedAt": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/transformers/{code}/meters": {
      "get": {
        "summary": "List meters under a transformer",
        "tags": [
          "Transformers"
        ],
        "description": "All smart meters attached to a specific distribution transformer. This is a derived endpoint — the portal doesn't have a direct equivalent.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "in": "path",
            "name": "code",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "meterId": {
                            "type": "string"
                          },
                          "serialNo": {
                            "type": "string"
                          },
                          "make": {
                            "type": "string"
                          },
                          "phaseType": {
                            "type": "string"
                          },
                          "installStatus": {
                            "type": "string"
                          },
                          "installType": {
                            "type": "string"
                          },
                          "build": {
                            "type": "string"
                          },
                          "dtCode": {
                            "type": "string"
                          },
                          "geo": {
                            "type": "object",
                            "nullable": true,
                            "properties": {
                              "latitude": {
                                "type": "number"
                              },
                              "longitude": {
                                "type": "number"
                              }
                            }
                          },
                          "syncedAt": {
                            "type": "string",
                            "format": "date-time"
                          }
                        }
                      }
                    },
                    "total": {
                      "type": "integer"
                    },
                    "transformerCode": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/health": {
      "get": {
        "summary": "Health check",
        "tags": [
          "System"
        ],
        "description": "Service health including upstream portal reachability and local data freshness.",
        "security": [],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "portal": {
                      "type": "object",
                      "properties": {
                        "reachable": {
                          "type": "boolean"
                        }
                      }
                    },
                    "database": {
                      "type": "object",
                      "properties": {
                        "meters": {
                          "type": "integer"
                        },
                        "transformers": {
                          "type": "integer"
                        },
                        "lastMeterSync": {
                          "type": "string",
                          "nullable": true
                        },
                        "lastTransformerSync": {
                          "type": "string",
                          "nullable": true
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sync": {
      "post": {
        "summary": "Trigger data sync",
        "tags": [
          "System"
        ],
        "description": "Manually trigger a re-sync of meters and transformers from the legacy portal. Energy readings are synced on-demand per meter and are not affected by this endpoint.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "synced": {
                      "type": "object",
                      "properties": {
                        "meters": {
                          "type": "integer"
                        },
                        "transformers": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development server"
    }
  ],
  "security": [
    {
      "apiKey": []
    }
  ],
  "tags": [
    {
      "name": "Meters",
      "description": "Smart meter data"
    },
    {
      "name": "Transformers",
      "description": "Distribution transformer data"
    },
    {
      "name": "System",
      "description": "Health and admin endpoints"
    }
  ]
}